<Window x:Class="View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:View"
        mc:Ignorable="d"
        Title="MainWindow" Height="444" Width="785">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Заголовок -->
            <RowDefinition Height="*"/>
            <!-- GroupBox'ы -->
            <RowDefinition Height="Auto"/>
            <!-- Кнопки -->
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <!-- Edit Contact -->
            <ColumnDefinition Width="10"/>
            <!-- Отступ между колонками -->
            <ColumnDefinition Width="*"/>
            <!-- Read Contact -->
        </Grid.ColumnDefinitions>

        
        <!-- Edit Contact (левая колонка) -->
        <GroupBox Grid.Row="1" 
                  Grid.Column="0"
                  Header="Edit Contact" 
                  Padding="8"
                  BorderBrush="#ccc">
            <StackPanel>
                <TextBlock Text="Name:" Margin="0,0,0,3"/>
                <TextBox Text ="{Binding Contact.Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                <TextBlock Text="Phone Number:" Margin="0,0,0,3"/>
                <TextBox Text ="{Binding Contact.Number, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,12"/>

                <TextBlock Text="Email:" Margin="0,0,0,3"/>
                <TextBox Text ="{Binding Contact.Email, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,0"/>
            </StackPanel>
        </GroupBox>

        <!-- Read Contact (правая колонка) -->
        <GroupBox Grid.Row="1" 
                  Grid.Column="2"
                  Header="Read Contact" 
                  Padding="8"
                  BorderBrush="#ccc">
            <StackPanel>
                <TextBlock Text="Name:" Margin="0,0,0,3"/>
                <TextBlock Text="{Binding Contact.Name}" 
                           Margin="0,0,0,12" 
                           FontSize="14"/>

                <TextBlock Text="Phone Number:" Margin="0,0,0,3"/>
                <TextBlock Text = "{Binding Contact.Number}"
                           Margin="0,0,0,12" 
                           FontSize="14"/>

                <TextBlock Text="Email:" Margin="0,0,0,3"/>
                <TextBlock Text="{Binding Contact.Email}" 
                           FontSize="14"/>
            </StackPanel>
        </GroupBox>

        <!-- Кнопки (внизу по центру) -->
        <StackPanel Grid.Row="2" 
                    Grid.Column="0" 
                    Grid.ColumnSpan="3"
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">
            <Button Content="Save" Width="75" Height="25" Margin="5"
            Command="{Binding SaveCommand}"/>
            <Button Content="Load" Width="75" Height="25" Margin="5"
            Command="{Binding LoadCommand}"/>
        </StackPanel>
    </Grid>
</Window>
