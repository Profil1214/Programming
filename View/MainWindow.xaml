<Window x:Class="View.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:View"
        mc:Ignorable="d"
        Title="MainWindow" Height="444" Width="785">
    <Grid Margin="15">
        <Button Content="Button" HorizontalAlignment="Left" Margin="555,355,0,0" VerticalAlignment="Top" Height="25" Width="75"/>
        <Button Content="Button" HorizontalAlignment="Left" Margin="658,355,0,0" VerticalAlignment="Top" Height="25" Width="75"/>
        <GroupBox Header="Edit Contact" Margin="15" Padding="5">
            <StackPanel>
                <!-- Name -->
                <WrapPanel Margin="0,0,0,3">
                    <TextBlock Text="Name:" Width="80" VerticalAlignment="Center"/>
                    <TextBox Text="Смирнов Юрий" Width="200"/>
                </WrapPanel>

                <!-- Phone Number -->
                <WrapPanel Margin="0,0,0,3">
                    <TextBlock Text="Phone Number:" Width="80" VerticalAlignment="Center"/>
                    <TextBox Text="+7-913-111-22-33" Width="200"/>
                </WrapPanel>

                <!-- Email -->
                <WrapPanel Margin="0,0,0,3">
                    <TextBlock Text="Email:" Width="80" VerticalAlignment="Center"/>
                    <TextBox Text="yuri.smirnov@no.mail" Width="200"/>
                </WrapPanel>
            </StackPanel>
        </GroupBox>
        <GroupBox Header="Read Contact" Margin="361,49,10,58"/>
        <TextBlock HorizontalAlignment="Left" Margin="370,72,0,0" TextWrapping="Wrap" Text="Name:" VerticalAlignment="Top"/>
        <TextBlock HorizontalAlignment="Left" Margin="370,113,0,0" TextWrapping="Wrap" Text="PhoneNumber:" VerticalAlignment="Top"/>
        <TextBlock HorizontalAlignment="Left" Margin="370,155,0,0" TextWrapping="Wrap" Text="Email:" VerticalAlignment="Top"/>
        <StackPanel>
            
        </StackPanel>
    </Grid>
</Window>
