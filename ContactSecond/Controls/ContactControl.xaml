<UserControl
  x:Class="ContactSecond.Controls.ContactControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:ContactSecond.Controls"
             xmlns:converters="clr-namespace:ContactSecond.ViewModel.Converters"
             mc:Ignorable="d" 
             x:Name="Root"
             d:DesignHeight="300" d:DesignWidth="400">
    
   

<Grid>
    <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <Border Width="100"
        VerticalAlignment="Top"
        Grid.Column="0"
        Height="100"
        Margin="0,25,0,0"
        HorizontalAlignment="Left">
            <Image Source="/doc/User.jpg"/>
    </Border>
    <StackPanel Grid.Column="1">
        <TextBlock 
                Text="Name:"
                Margin="3,0,0,0"/>
        <TextBox
                Margin="3,8,0,0"
                IsReadOnly="{Binding IsReadOnly, ElementName=Root}"
                Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
            />
        <TextBlock
                Text="Phone Number:"
                Margin="3,8,0,0"/>
        <TextBox
               Margin="3,8,0,0"
               IsReadOnly="{Binding IsReadOnly, ElementName=Root}"
               Text="{Binding PhoneNumber, UpdateSourceTrigger=PropertyChanged}"/>
        <TextBlock Text="Email"
                   Margin="3,8,0,0"/>
        <TextBox Margin="3,8,0,0"
               IsReadOnly="{Binding IsReadOnly, ElementName=Root}"
               Text="{Binding Email, UpdateSourceTrigger=PropertyChanged}"/>
    </StackPanel>
</Grid>
</UserControl>