<Window x:Class="ContactSecond.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ContactSecond"
        xmlns:converters="clr-namespace:ContactSecond.ViewModel.Converters"
        xmlns:views="clr-namespace:ContactSecond.Controls"
        mc:Ignorable="d"
        Title="Contact" Height="450" Width="800"
        x:Name="MainWindowRoot">



    <Window.Resources>
        <converters:FirstValidationErrorConverter x:Key="FirstValidationErrorConverter"/>
        <converters:InverseBooleanConverter x:Key="InverseBooleanConverter"/>

        <Style TargetType="TextBox">
            <Setter Property="ToolTip" Value="{Binding (Validation.Errors), RelativeSource={RelativeSource Self}, Converter={StaticResource FirstValidationErrorConverter}}"/>
            <Style.Triggers>
                <Trigger Property="Validation.HasError" Value="True">
                    <Setter Property="Background" Value="#33FF0000"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="5">

        <Grid.RowDefinitions>
            <RowDefinition Height= "*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="10"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <GridSplitter Grid.Column="1" ShowsPreview="False" Width="3" 
                      HorizontalAlignment="Center" VerticalAlignment="Stretch"/>
          
        <GroupBox Grid.Row="0" 
                  Grid.Column="0"
                  Padding="8"
                  BorderBrush="#f8f8f8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="auto"/>
                </Grid.RowDefinitions>
                <Grid Margin="0,0,0,5" Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column ="0"  Text="Find:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBox Grid.Column ="1" />
                </Grid>
                
                <ListBox 
                    
                    Grid.Column="0"
                    Margin="3"
                    Grid.Row="1"
                    Grid.ColumnSpan="3"
                    ItemsSource="{Binding Contacts}"
                    SelectedItem="{Binding SelectedContact}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="3">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                
                                <Image Grid.Column="0" 
                                       Source="/Doc/User.jpg"
                                       Width="40"
                                       Height="40"
                                       VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="1"
                                            Margin="8,0,0,0"
                                            VerticalAlignment="Center">
                                    <TextBlock
                                        FontSize="12"
                                        FontWeight="SemiBold"
                                        Text="{Binding Name}"/>
                                    <TextBlock
                                        FontSize="10"
                                        Text="{Binding PhoneNumber}"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                    
                </ListBox>
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width = "*"/>
                        <ColumnDefinition Width= "*"/>
                        <ColumnDefinition Width= "*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Margin="0,0,3,0" Content="Add" Command="{Binding AddCommand}" Height="25" />
                    <Button Grid.Column="1" Margin="0,0,3,0" Content="Edit" Command ="{Binding EditCommand}"  Height="25" 
                            />
                    <Button Grid.Column="2" Margin="0,0,0,0" Content="Remove" Command="{Binding RemoveCommand}" Height="25"/>
                    
                </Grid>
            </Grid>
        </GroupBox>
        <GroupBox Grid.Row="0"
                  Grid.Column="2"
                  Padding="8">
            <StackPanel>
                <views:ContactControl 
                     DataContext="{Binding SelectedContact}"
                     IsReadOnly="{Binding DataContext.IsAddingNew, ElementName=MainWindowRoot, Converter={StaticResource InverseBooleanConverter}}"/>
                <Button Content="Apply" 
                     Command="{Binding ApplyCommand}"
                     Width="75"
                     Height="25"
                     Margin="105,50,0,0"
                     HorizontalAlignment="Left"
                     Visibility="{Binding IsAddingNew, Converter={StaticResource InverseBooleanConverter}}">
                </Button>
            </StackPanel>
        </GroupBox>
    </Grid>
</Window>
